# Copy this file to .env and fill values.
# .env is git-ignored and should never be committed.

# YNAB personal access token used by `setup ynab --token-env YNAB_TOKEN`
YNAB_TOKEN=

# Optional: IMAP password used by `setup email --imap-pass-cmd "printf '%s' \"$FINTRACK_IMAP_PASS\""`
FINTRACK_IMAP_PASS=
